@startuml diagrama-secuencia

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam sequenceFontSize 12

title Disparo exitoso de T2 (conflicto T2 vs T3 en P3)\nH3 — S_superior, política autoriza

actor "SegmentoIntermedio\n(H3 — S_superior)" as Thread
participant Monitor
participant RedPetri
participant Politica
participant Logger

Thread -> Monitor : fireTransition(2)
activate Monitor

Monitor -> Monitor : lock.lock()

note over Monitor
  Evalúa listaParaDisparar(2):
  (1) estaHabilitada(2)?
  (2) esConflicto(2) && debeDisparar(2)?
  (3) esTemporal(2)? → NO (T2 es inmediata)
end note

Monitor -> RedPetri : estaHabilitada(2)
activate RedPetri
RedPetri --> Monitor : true
deactivate RedPetri

note right of Monitor
  esConflicto(2) = true
  T2 ∈ TRANSICIONES_CONFLICTO = {2, 3, 6, 7}
end note

Monitor -> Politica : debeDisparar(2)
activate Politica
Politica --> Monitor : true
deactivate Politica

note over Monitor
  T2 no es temporal → sin awaitUntil
  listaParaDisparar(2) = true → sale del while
end note

Monitor -> RedPetri : disparar(2)
activate RedPetri
note right of RedPetri : M ← M + Post[2] − Pre[2]
RedPetri --> Monitor : (void)
deactivate RedPetri

Monitor -> RedPetri : verificarInvariantesPlaza()
activate RedPetri
note right of RedPetri : valida PI-1..PI-6\nlanza ViolacionInvarianteException si falla
RedPetri --> Monitor : (ok)
deactivate RedPetri

Monitor -> Politica : registrarDisparo(2)
activate Politica
note right of Politica : c2++\n(separado de debeDisparar para\nevitar efectos en el while)
Politica --> Monitor : (void)
deactivate Politica

Monitor -> Logger : registrar(2)
activate Logger
note right of Logger : escribe "T2\n" en el log
Logger --> Monitor : (void)
deactivate Logger

note over Monitor
  Actualiza relojes: para cada transición i
  • Si recién habilitada: tiempoHabilitacion[i] = ahora
                          tiempoObjetivo[i] = ahora + alfa
  • Si deshabilitada:     tiempoHabilitacion[i] = −1

  Señalización dirigida por política:
  candidatos = sensibilizadas ∩ conHilosEsperando
  ganador = politica.cualDisparar(candidatos)
  condiciones[ganador].signal()
end note

Monitor -> Politica : cualDisparar(candidatos)
activate Politica
Politica --> Monitor : ganador
deactivate Politica

Monitor -> Monitor : condiciones[ganador].signal()

Monitor -> Monitor : lock.unlock()

Monitor --> Thread : true
deactivate Monitor

@enduml
